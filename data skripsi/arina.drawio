<mxfile host="app.diagrams.net" pages="6">
  <diagram name="usecase" id="TatYY22y0Q5zlpuHVy-k">
    <mxGraphModel dx="1862" dy="1664" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UseCase_Klasifikasi_Kesejahteraan\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam actorStyle awesome\nskinparam usecase {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  BorderThickness 1.5\n  FontSize 11\n}\nskinparam actor {\n  BackgroundColor #FDF3E3\n  BorderColor #D19900\n  FontSize 12\n  FontStyle bold\n}\nskinparam ArrowColor #7A7974\nskinparam ArrowThickness 1.2\nskinparam packageStyle rectangle\nskinparam package {\n  BackgroundColor #FAFAF8\n  BorderColor #D4D1CA\n  BorderThickness 2\n  FontSize 13\n  FontColor #01696F\n  FontStyle bold\n}\nskinparam note {\n  BackgroundColor #FFFBEC\n  BorderColor #D19900\n}\n\nleft to right direction\n\nactor \&quot;Admin\\n(Petugas Desa)\&quot; as Admin #EEF5F5\nactor \&quot;Operator\\n(Enumerator)\&quot; as Operator #FDF3E3\n\nrectangle \&quot;Sistem Klasifikasi Tingkat Kesejahteraan Masyarakat\\n(Golang + SQLite Desktop App)\&quot; {\n\n  package \&quot;Autentikasi\&quot; {\n    usecase \&quot;UC-01\\nLogin Sistem\&quot; as UC01\n    usecase \&quot;UC-02\\nKelola Data User\\n(CRUD Akun)\&quot; as UC02\n  }\n\n  package \&quot;Manajemen Data\&quot; {\n    usecase \&quot;UC-03\\nInput / Import\\nData Warga\&quot; as UC03\n    usecase \&quot;UC-04\\nKelola 36 Indikator\\n(IM 1 - IM 36)\&quot; as UC04\n  }\n\n  package \&quot;Training Model Naive Bayes\&quot; {\n    usecase \&quot;UC-05\\nInisiasi Training\\nModel NB\&quot; as UC05\n    usecase \&quot;UC-06\\nHitung Prior\\nP(Ck) = nk / N\&quot; as UC06\n    usecase \&quot;UC-07\\nHitung Likelihood\\nP(Xi|Ck) + Laplace\&quot; as UC07\n    usecase \&quot;UC-08\\nEvaluasi Model\\n(Confusion Matrix 6x6)\&quot; as UC08\n    usecase \&quot;UC-09\\nLihat Akurasi\\nModel (90%)\&quot; as UC09\n  }\n\n  package \&quot;Klasifikasi Warga\&quot; {\n    usecase \&quot;UC-10\\nInput 36 Indikator\\nWarga Baru\&quot; as UC10\n    usecase \&quot;UC-11\\nProses Klasifikasi\\n(argmax log P(Ck|X))\&quot; as UC11\n    usecase \&quot;UC-12\\nLihat Hasil &amp;\\nProbabilitas 6 Kelas\&quot; as UC12\n  }\n\n  package \&quot;Laporan &amp; Export\&quot; {\n    usecase \&quot;UC-13\\nLihat Rekap\\nLaporan Warga\&quot; as UC13\n    usecase \&quot;UC-14\\nExport PDF /\\nExcel\&quot; as UC14\n  }\n}\n\n&#39; === ADMIN ASSOCIATIONS ===\nAdmin --&gt; UC01\nAdmin --&gt; UC02\nAdmin --&gt; UC03\nAdmin --&gt; UC04\nAdmin --&gt; UC05\nAdmin --&gt; UC08\nAdmin --&gt; UC09\nAdmin --&gt; UC13\nAdmin --&gt; UC14\n\n&#39; === OPERATOR ASSOCIATIONS ===\nOperator --&gt; UC01\nOperator --&gt; UC10\nOperator --&gt; UC12\nOperator --&gt; UC13\n\n&#39; === INCLUDE RELATIONS ===\nUC05 .&gt; UC06 : &lt;&lt;include&gt;&gt;\nUC05 .&gt; UC07 : &lt;&lt;include&gt;&gt;\nUC05 .&gt; UC08 : &lt;&lt;include&gt;&gt;\nUC11 .&gt; UC06 : &lt;&lt;include&gt;&gt;\nUC11 .&gt; UC07 : &lt;&lt;include&gt;&gt;\n\n&#39; === EXTEND RELATIONS ===\nUC10 .&gt; UC11 : &lt;&lt;extend&gt;&gt;\nUC11 .&gt; UC12 : &lt;&lt;extend&gt;&gt;\nUC08 .&gt; UC09 : &lt;&lt;extend&gt;&gt;\nUC13 .&gt; UC14 : &lt;&lt;extend&gt;&gt;\n\nnote right of UC07\n  Laplace Smoothing:\n  P(Xi=v|Ck) = (count+1) / (nk + |V|)\n  Menghindari probabilitas = 0\nend note\n\nnote right of UC11\n  argmax score(k):\n  score(k) = log P(Ck) +\n  Sigma log P(Xi=vi | Ck)\n  untuk k = 1, 2, 3, 4, 5, 6\nend note\n\nnote bottom of UC08\n  Confusion Matrix 6x6:\n  Akurasi = 54/60 = 90%\n  (6 data salah klasifikasi)\nend note\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="xGWJmMSYasE27aEenPu2-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1544" width="876" x="-26" y="-30" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="C6rW3tf8-0yxeXwMPqCz" name="dfd_level0">
    <mxGraphModel dx="860" dy="479" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml DFD_Level0_Context_Diagram\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam rectangle {\n  BackgroundColor #FDF3E3\n  BorderColor #D19900\n  BorderThickness 1.5\n  FontSize 12\n  FontStyle bold\n  RoundCorner 8\n}\nskinparam database {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  BorderThickness 2\n  FontSize 13\n  FontStyle bold\n}\nskinparam ArrowColor #7A7974\nskinparam ArrowThickness 1.4\nskinparam ArrowFontSize 10\nskinparam ArrowFontColor #28251D\nskinparam note {\n  BackgroundColor #FFFBEC\n  BorderColor #D19900\n}\n\ntitle DFD Level 0 - Context Diagram\\nSistem Klasifikasi Tingkat Kesejahteraan Masyarakat\n\n&#39; === EXTERNAL ENTITIES ===\nrectangle \&quot;Admin\\n(Petugas Desa)\&quot; as Admin\nrectangle \&quot;Operator\\n(Enumerator)\&quot; as Operator\nrectangle \&quot;Sumber Data\\nPBDT 2015\&quot; as PBDT\nrectangle \&quot;Output\\nLaporan\&quot; as Laporan\n\n&#39; === CENTRAL PROCESS ===\ndatabase \&quot;0\\nSistem Klasifikasi\\nTingkat Kesejahteraan\\nMasyarakat\\n(Naive Bayes\\nGolang + SQLite)\&quot; as Sistem\n\n&#39; === DATA FLOWS ===\nAdmin --&gt; Sistem : Kredensial Login\\n+ Perintah Training\nSistem --&gt; Admin : Akurasi Model (90%)\\n+ Confusion Matrix 6x6\\n+ Laporan Rekap\n\nOperator --&gt; Sistem : 36 Nilai Indikator\\n(IM 1 - IM 36) per KK\nSistem --&gt; Operator : Hasil Kelas Kesejahteraan\\n(1-6) + Probabilitas\n\nPBDT --&gt; Sistem : 60 Data Latih\\n(10 data x 6 kelas)\\n+ 36 Indikator per data\nSistem --&gt; Laporan : Rekap Hasil Klasifikasi\\nSeluruh Warga\\n(PDF / Excel)\n\nnote bottom of Sistem\n  Input  : 36 Indikator Majemuk (IM 1-IM 21)\n           &amp; Individual (IL 1-IL 15)\n  Output : Kelas Kesejahteraan 1 (Terendah)\n           s.d. 6 (Tertinggi)\n  Metode : Naive Bayes + Laplace Smoothing\n  Data   : 60 training | 6 kelas | akurasi 90%\nend note\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="nN0TvV6-kBM3XHZGI_n2-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="526" width="725" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="S1EMlJciK9BkLjvAp4Gb" name="dfd_level1">
    <mxGraphModel dx="3000" dy="2298" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml DFD_Level1\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam rectangle {\n  BackgroundColor #FDF3E3\n  BorderColor #D19900\n  BorderThickness 1.5\n  FontSize 11\n  RoundCorner 6\n}\nskinparam database {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  FontSize 10\n}\nskinparam ArrowColor #7A7974\nskinparam ArrowThickness 1.2\nskinparam ArrowFontSize 9\nskinparam ArrowFontColor #28251D\n\ntitle DFD Level 1 - Dekomposisi Proses\\nSistem Klasifikasi Tingkat Kesejahteraan\n\n&#39; === EXTERNAL ENTITIES ===\nrectangle \&quot;Admin\&quot; as Admin\nrectangle \&quot;Operator\&quot; as Operator\n\n&#39; === DATA STORES ===\ndatabase \&quot;DS-1\\nData Warga\\n(NIK, KK, Alamat)\&quot; as DS1\ndatabase \&quot;DS-2\\nIndikator Ekonomi\\n(36 IM per warga)\&quot; as DS2\ndatabase \&quot;DS-3\\nModel Naive Bayes\\n(P(Ck), P(Xi|Ck))\&quot; as DS3\ndatabase \&quot;DS-4\\nHasil Klasifikasi\\n(kelas + prob.)\&quot; as DS4\ndatabase \&quot;DS-5\\nData Users\\n(auth)\&quot; as DS5\n\n&#39; === PROCESSES ===\n(P1\\nAutentikasi\\nLogin) as P1\n(P2\\nKelola Data\\nWarga &amp; Indikator) as P2\n(P3\\nTraining Model\\nNaive Bayes) as P3\n(P4\\nKlasifikasi\\nWarga Baru) as P4\n(P5\\nGenerate\\nLaporan) as P5\n\n&#39; === FLOWS ===\nAdmin --&gt; P1 : Username + Password\nP1 --&gt; DS5 : Verifikasi Kredensial\nDS5 --&gt; P1 : Status Valid/Gagal\nP1 --&gt; Admin : Token Sesi / Error\n\nAdmin --&gt; P2 : Data Warga Baru\nP2 --&gt; DS1 : Simpan/Update Data Warga\nP2 --&gt; DS2 : Simpan 36 Nilai Indikator\nDS1 --&gt; P2 : Data Warga\nDS2 --&gt; P2 : Data Indikator\n\nAdmin --&gt; P3 : Perintah Mulai Training\nDS2 --&gt; P3 : 60 Data Latih (IM 1-36)\nP3 --&gt; DS3 : Simpan P(Ck) + P(Xi|Ck)\\n+ Laplace Smoothed\nDS3 --&gt; P3 : Konfirmasi Simpan\nP3 --&gt; Admin : Akurasi (90%)\\n+ Confusion Matrix\n\nOperator --&gt; P4 : 36 Nilai Indikator\\nWarga Baru\nDS3 --&gt; P4 : Load Model Aktif\\n(Parameter NB)\nP4 --&gt; DS4 : Simpan Hasil Kelas\\n+ Probabilitas\nP4 --&gt; Operator : Kelas 1-6\\n+ Bar Probabilitas\n\nDS4 --&gt; P5 : Semua Hasil Klasifikasi\nDS3 --&gt; P5 : Info Model (Akurasi)\nAdmin --&gt; P5 : Request Laporan\nOperator --&gt; P5 : Request Laporan\nP5 --&gt; Admin : PDF / Excel Laporan\nP5 --&gt; Operator : PDF / Excel Laporan\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="IpI3wOdoflMhvcbVHNaT-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1210" width="1303" x="-250" y="-120" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="3KzqOlC3fPqwh1Nt-FU7" name="flowchart_main">
    <mxGraphModel dx="1229" dy="684" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Flowchart_Main_Login_Navigasi\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam activity {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  BorderThickness 1.5\n  FontSize 11\n  DiamondBackgroundColor #FFFBEC\n  DiamondBorderColor #D19900\n  StartColor #01696F\n  EndColor #01696F\n  ArrowColor #7A7974\n}\nskinparam ArrowFontSize 10\nskinparam ArrowFontColor #01696F\nskinparam note {\n  BackgroundColor #FFFBEC\n  BorderColor #D19900\n  FontSize 10\n}\n\ntitle Flowchart Utama - Login &amp; Navigasi Sistem\n\nstart\n\n:Input Username &amp; Password;\nnote right: Form login Admin / Operator\n\nif (Kredensial Valid?) then (Ya)\n  :Tampilkan Dashboard Utama;\n  note right\n    KPI: Total Warga Terklasifikasi,\n    Model Aktif, Akurasi Terakhir\n  end note\n\n  repeat\n    :Pilih Menu;\n\n    if (Menu Dipilih?) then (Training)\n      :Ke Sub-Flow A\\n(Training Model NB);\n\n    else if (Menu Dipilih?) then (Klasifikasi)\n      :Ke Sub-Flow B\\n(Klasifikasi Warga);\n\n    else if (Menu Dipilih?) then (Laporan)\n      :Tampilkan Laporan;\n      :Filter Periode / Kelas;\n      :Export PDF atau Excel;\n\n    else (Kelola Data)\n      :CRUD Data Warga;\n      :Input / Edit 36 Indikator;\n    endif\n\n  repeat while (Lanjut Gunakan Sistem?) is (Ya)\n  -&gt;Tidak;\n  :Logout;\n\nelse (Tidak)\n  :Tampilkan Pesan Error\\n\&quot;Username/Password Salah\&quot;;\n  note right: Maksimal 3x percobaan\n  :Kembali ke Form Login;\n  stop\nendif\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="jN6gzUcRHN13NVjxU9f--1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="755" width="958" x="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="7oRguYM5UpxFfGht1oiR" name="flowchart_training">
    <mxGraphModel dx="860" dy="479" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Flowchart_SubFlowA_Training_Naive_Bayes\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam activity {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  BorderThickness 1.5\n  FontSize 11\n  DiamondBackgroundColor #FFFBEC\n  DiamondBorderColor #D19900\n  StartColor #01696F\n  EndColor #01696F\n  ArrowColor #7A7974\n}\nskinparam ArrowFontSize 10\nskinparam note {\n  BackgroundColor #FFFBEC\n  BorderColor #D19900\n  FontSize 10\n}\nskinparam partition {\n  BackgroundColor #F0F7F7\n  BorderColor #01696F\n  FontColor #01696F\n  FontStyle bold\n}\n\ntitle Sub-Flow A - Training Model Naive Bayes\n\nstart\n\n:Admin klik tombol \&quot;Mulai Training\&quot;;\n\n:Ambil Data Latih dari Database\\n(Tabel: indikator_ekonomi);\n\nif (Jumlah Data &gt;= 60\\n(10 per kelas x 6 kelas)?) then (Ya)\n\n  partition \&quot;Langkah 1: Hitung Prior P(Ck)\&quot; {\n    :Untuk setiap kelas k (1 sampai 6);\n    :Hitung P(Ck) = nk / N\\ndimana N = 60, nk = 10;\n    note right\n      P(K1) = P(K2) = ... = P(K6)\n      = 10/60 = 0.1667 (balanced)\n    end note\n    :Simpan P(Ck) ke tabel\\nprobabilitas_kelas;\n  }\n\n  partition \&quot;Langkah 2: Hitung Likelihood P(Xi|Ck)\&quot; {\n    :Loop: untuk setiap fitur i = 1 sampai 36;\n    :Loop: untuk setiap kelas k = 1 sampai 6;\n    :Loop: untuk setiap nilai v dalam {A, B, C, D};\n    :Hitung count(Xi=v, Ck) dari data training;\n    :Terapkan Laplace Smoothing:\\nP(Xi=v|Ck) = (count+1) / (nk + |V|)\\n|V| = 4 (nilai A, B, C, D);\n    note right\n      Laplace Smoothing mencegah\n      probabilitas = 0 saat nilai\n      fitur tidak muncul di training\n    end note\n    :Simpan ke tabel probabilitas_fitur\\n(36 fitur x 4 nilai x 6 kelas = 864 baris);\n  }\n\n  partition \&quot;Langkah 3: Simpan Model\&quot; {\n    :Buat record di tabel model_naive_bayes\\n(nama, tanggal, status = aktif);\n    :Set model lama status = nonaktif;\n    :Commit transaksi SQLite;\n  }\n\n  partition \&quot;Langkah 4: Evaluasi Model\&quot; {\n    :Jalankan prediksi pada 60 data training;\n    :Bangun Confusion Matrix 6x6\\n(aktual vs prediksi);\n    :Hitung Akurasi = benar / total\\n= 54 / 60 = 90%;\n    :Hitung Presisi, Recall, F1-Score\\nper kelas kesejahteraan;\n  }\n\n  :Tampilkan Hasil Training:\\n- Confusion Matrix 6x6\\n- Akurasi: 90%\\n- Model tersimpan dengan ID baru;\n\nelse (Tidak)\n  :Tampilkan Error:\\n\&quot;Data latih tidak cukup.\\nMinimal 60 data (10 per kelas)\&quot;;\n  stop\nendif\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="M102hgIoEo7nhFh2T3zK-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1461" width="673" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="ypWcYGdRR_2Htdd1QpOp" name="flowchart_klasifikasi">
    <mxGraphModel dx="1564" dy="871" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Flowchart_SubFlowB_Klasifikasi_Warga\n!theme plain\nskinparam backgroundColor #F7F6F2\nskinparam activity {\n  BackgroundColor #EEF5F5\n  BorderColor #01696F\n  BorderThickness 1.5\n  FontSize 11\n  DiamondBackgroundColor #FFFBEC\n  DiamondBorderColor #D19900\n  StartColor #01696F\n  EndColor #01696F\n  ArrowColor #7A7974\n}\nskinparam ArrowFontSize 10\nskinparam note {\n  BackgroundColor #FFFBEC\n  BorderColor #D19900\n  FontSize 10\n}\nskinparam partition {\n  BackgroundColor #F0F7F7\n  BorderColor #01696F\n  FontColor #01696F\n  FontStyle bold\n}\n\ntitle Sub-Flow B - Klasifikasi Warga Baru\n\nstart\n\n:Operator membuka Form Input Klasifikasi;\n\nif (Model Aktif Tersedia\\ndi Database?) then (Ya)\n\n  partition \&quot;Input Data\&quot; {\n    :Input Identitas Warga\\n(NIK, Nama, Alamat, No. KK);\n    :Input 36 Nilai Indikator:\\n- IM 1 s.d. IM 21 (Majemuk)\\n- IL 1 s.d. IL 15 (Individual)\\nNilai: A / B / C / D;\n  }\n\n  if (Semua 36 Field\\nTerisi Lengkap?) then (Ya)\n\n    partition \&quot;Proses Klasifikasi Naive Bayes\&quot; {\n      :Load Parameter Model Aktif dari DB:\\n- P(Ck) untuk k = 1..6\\n- P(Xi|Ck) untuk i = 1..36;\n\n      :Inisialisasi score(k) = log P(Ck)\\nuntuk setiap kelas k = 1 s.d. 6;\n\n      :Loop i = 1 sampai 36;\n      :score(k) += log P(Xi=vi | Ck)\\nuntuk semua kelas k secara bersamaan;\n      note right\n        Menggunakan log untuk menghindari\n        underflow numerik saat mengalikan\n        banyak probabilitas kecil\n      end note\n\n      :Tentukan Kelas Prediksi:\\nkelas = argmax(score(k))\\nk dalam {1, 2, 3, 4, 5, 6};\n    }\n\n    partition \&quot;Tampilkan &amp; Simpan Hasil\&quot; {\n      :Normalisasi score ke probabilitas\\nmenggunakan softmax;\n      :Tampilkan:\\n- Kelas Kesejahteraan (1-6)\\n- Bar probabilitas 6 kelas\\n- Deskripsi kelas;\n\n      if (Simpan Hasil ke\\nDatabase?) then (Ya)\n        :Simpan ke tabel hasil_klasifikasi:\\n- warga_id, model_id, kelas_prediksi\\n- probabilitas 6 kelas\\n- tanggal klasifikasi;\n        :Konfirmasi \&quot;Data berhasil disimpan\&quot;;\n      else (Tidak / Batal)\n        :Tampilkan hasil tanpa menyimpan;\n      endif\n    }\n\n  else (Tidak - Ada Field Kosong)\n    :Highlight field kosong\\ndengan warna merah;\n    :Tampilkan pesan:\\n\&quot;Lengkapi semua 36 indikator\&quot;;\n    :Kembali ke Form Input;\n  endif\n\nelse (Tidak - Belum Ada Model)\n  :Tampilkan pesan:\\n\&quot;Model belum tersedia.\\nLakukan Training terlebih dahulu.\&quot;;\n  :Arahkan ke Menu Training;\n  stop\nendif\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ceU7ALmR3WHcOU3jU0mY-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1276" width="1006" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
